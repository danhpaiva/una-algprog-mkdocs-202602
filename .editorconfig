# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space

# Markdown: 4 espaços (admonitions/abas do Material exigem recuo de 4).
# trim_trailing_whitespace = false: 2 espaços no fim = quebra de linha no MD.
[*.md]
indent_size = 4
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4
